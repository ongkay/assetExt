{
  "manifest_version": 3,
  "name": "Asset Manager ext-2",
  "description": "Local watchdog companion for Asset Manager ext-1.",
  "version": "2.0.0",
  "key": "",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["cookies", "management", "storage", "tabs"],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://www.tradingview.com/*",
    "https://*.tradingview.com/*",
    "https://whoer.net/*",
    "https://*.whoer.net/*",
    "https://forextester.com/*",
    "https://*.forextester.com/*",
    "https://browserscan.net/*",
    "https://*.browserscan.net/*",
    "https://tv.checkout.com/*",
    "https://*.tv.checkout.com/*"
  ],
  "background": {
    "service_worker": "src/ext-2/background/index.ts",
    "type": "module"
  }
}
