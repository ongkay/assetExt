{
  "manifest_version": 3,
  "name": "Asset Manager ext-1",
  "description": "Premium asset access manager for authenticated subscribers.",
  "version": "2.0.0",
  "key": "",
  "action": {
    "default_title": "Asset Manager ext-1",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": [
    "alarms",
    "cookies",
    "declarativeNetRequestWithHostAccess",
    "management",
    "proxy",
    "storage",
    "tabs",
    "webRequest",
    "webRequestAuthProvider"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://www.tradingview.com/*",
    "https://*.tradingview.com/*",
    "https://whoer.net/*",
    "https://*.whoer.net/*",
    "https://forextester.com/*",
    "https://*.forextester.com/*",
    "https://browserscan.net/*",
    "https://*.browserscan.net/*",
    "https://tv.checkout.com/*",
    "https://*.tv.checkout.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["proxy-blocked.html", "ext-1-blocked.html", "assets/*"],
      "matches": [
        "https://www.tradingview.com/*",
        "https://*.tradingview.com/*",
        "https://whoer.net/*",
        "https://*.whoer.net/*",
        "https://forextester.com/*",
        "https://*.forextester.com/*",
        "https://browserscan.net/*",
        "https://*.browserscan.net/*"
      ]
    }
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.tradingview.com/*",
        "https://*.tradingview.com/*",
        "https://whoer.net/*",
        "https://*.whoer.net/*",
        "https://forextester.com/*",
        "https://*.forextester.com/*",
        "https://browserscan.net/*",
        "https://*.browserscan.net/*"
      ],
      "js": ["src/content/index.tsx"],
      "run_at": "document_start"
    }
  ]
}
